# Server Configuration
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/v_ad_db
# DATABASE_URL=postgresql://v_ad:8862@localhost:5432/v_ad_db

# Redis Queue
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your_secret_key_change_in_production

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIASG6ZW6KNKFKKS3GJ
AWS_SECRET_ACCESS_KEY=PeEXRmrBpWhnlOwbKJ7tmbb+S1aB4kA1+bGTKMv

# S3 Buckets
S3_BUCKET_NAME=v-ad-videos
S3_UPLOAD_BUCKET=v-ad-uploads

# Bedrock AI (Optional - for script generation)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=2000

# Use mock Bedrock response (for local development without AWS)
USE_MOCK_BEDROCK=true

# Video Processing
MAX_CONCURRENT_JOBS=5
VIDEO_TEMP_DIR=./temp
VIDEO_OUTPUT_DIR=./videos
WATERMARK_ENABLED=false

# Logging
LOG_LEVEL=info

